# Copy to .env.local and fill in. .env.local is gitignored.

# --- Database (Neon / Postgres) ---
# Neon — from the dashboard, Connect → "Pooled connection" (HTTP driver):
#   DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# --- Auth (multi-user, email + password) ---
# AUTH_SECRET: signs session cookies. Generate with:  openssl rand -base64 32
# OWNER_EMAIL: the account allowed to sign up without an invite and to send
#   invites. On the owner's first sign-up the existing library is adopted.
# Invited users sign up at /signup; the per-user iOS Shortcuts token is created
# from Settings → Account. (APP_PASSWORD / API_TOKEN are no longer used.)
AUTH_SECRET=
OWNER_EMAIL=you@example.com

# --- Book metadata lookup (optional) ---
# The "add a book" search uses Google Books, then falls back to Open Library
# (no key needed). A free Google Books API key lifts the per-IP rate limit that
# otherwise 429s from shared/datacenter IPs. https://console.cloud.google.com
GOOGLE_BOOKS_API_KEY=
